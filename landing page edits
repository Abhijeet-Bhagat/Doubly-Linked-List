  private heroRevealed = false;

  ngAfterViewInit(): void {
    document.addEventListener('loaderComplete', () => {
      if (this.heroRevealed) return;
      this.heroRevealed = true;

      const hero = document.querySelector(
        '.hero-section') as HTMLElement;
      if (hero) hero.style.visibility = 'visible';

      this.revealHero();
    });
  }

  private revealHero(): void {
    this.reveal('hero-eyebrow',  0,    700);
    this.reveal('hero-line-1',   350,  850);
    this.reveal('hero-line-2',   750,  850);
    this.reveal('hero-line-3',   1100, 950);
    this.reveal('hero-body',     1600, 650);
    setTimeout(() => this.revealCTAs(), 2000);
  }

  private reveal(id: string, delay: number, dur: number): void {
    setTimeout(() => {
      const el = document.getElementById(id);
      if (!el) return;
      el.style.transition =
        `opacity ${dur}ms ease, filter ${dur}ms ease`;
      el.style.opacity = '1';
      el.style.filter  = 'blur(0px)';
    }, delay);
  }

  private revealCTAs(): void {
    const el = document.getElementById('hero-ctas');
    if (!el) return;
    el.style.transition =
      'opacity 650ms ease, ' +
      'transform 650ms cubic-bezier(0.16, 1, 0.3, 1)';
    el.style.opacity   = '1';
    el.style.transform = 'translateY(0)';
  }

