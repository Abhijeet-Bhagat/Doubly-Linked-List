### 1F — BackgroundComponent TypeScript — COMPLETE

background.component.ts:

import {
  Component, OnInit, OnDestroy,
  AfterViewInit, ViewChild, ElementRef,
  HostListener
} from '@angular/core';
import * as THREE from 'three';

@Component({
  selector: 'app-background',
  templateUrl: './background.component.html',
  styleUrls: ['./background.component.scss']
})
export class BackgroundComponent implements AfterViewInit, OnDestroy {

  @ViewChild('bgCanvas') canvasRef!: ElementRef<HTMLCanvasElement>;

  private renderer!: THREE.WebGLRenderer;
  private scene!: THREE.Scene;
  private camera!: THREE.PerspectiveCamera;
  private animationId!: number;

  private layer1!: THREE.Points;
  private layer2!: THREE.Points;
  private layer3!: THREE.Points;

  private targetX = 0;
  private targetY = 0;

  private gradientEl!: HTMLElement;

  ngAfterViewInit(): void {
    this.initThree();
    this.gradientEl = document.querySelector(
      '.bg-gradient-layer'
    ) as HTMLElement;
  }

  /* ── THREE.JS INIT ── */
  private initThree(): void {
    const canvas = this.canvasRef.nativeElement;
    const W = window.innerWidth;
    const H = window.innerHeight;

    /* Renderer */
    this.renderer = new THREE.WebGLRenderer({
      canvas,
      alpha: false,
      antialias: false,
    });
    this.renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    this.renderer.setSize(W, H);
    this.renderer.setClearColor(0x040C0A, 1);

    /* Scene */
    this.scene = new THREE.Scene();

    /* Camera */
    this.camera = new THREE.PerspectiveCamera(60, W / H, 1, 3000);
    this.camera.position.z = 800;

    /* Build 3 particle layers */
    this.layer1 = this.makeLayer(1200, 4000, 600, 800,
      0x004D3A, 0.8, 0.25);
    this.layer2 = this.makeLayer(600,  3000, 400, 200,
      0x00A878, 1.4, 0.45);
    this.layer3 = this.makeLayer(180,  2000, 200, 0,
      0x00C896, 2.2, 0.65);

    this.scene.add(this.layer1, this.layer2, this.layer3);

    /* Start loop */
    this.animate();
  }

  private makeLayer(
    count: number,
    spread: number,
    zSpread: number,
    zOffset: number,
    color: number,
    size: number,
    opacity: number
  ): THREE.Points {
    const geo = new THREE.BufferGeometry();
    const pos = new Float32Array(count * 3);

    for (let i = 0; i < count; i++) {
      pos[i * 3]     = (Math.random() - 0.5) * spread;
      pos[i * 3 + 1] = (Math.random() - 0.5) * spread;
      pos[i * 3 + 2] = (Math.random() - 0.5) * zSpread - zOffset;
    }

    geo.setAttribute('position',
      new THREE.BufferAttribute(pos, 3));

    const mat = new THREE.PointsMaterial({
      color,
      size,
      transparent: true,
      opacity,
      sizeAttenuation: true,
      depthWrite: false,
    });

    return new THREE.Points(geo, mat);
  }

  /* ── ANIMATION LOOP ── */
  private animate(): void {
    this.animationId = requestAnimationFrame(() => this.animate());

    /* Rotate layers at different speeds */
    this.layer1.rotation.y += 0.00015;
    this.layer1.rotation.x += 0.00005;

    this.layer2.rotation.y += 0.00022;
    this.layer2.rotation.x += 0.00008;

    this.layer3.rotation.y += 0.00028;
    this.layer3.rotation.x += 0.00010;

    /* Smooth camera follow mouse */
    this.camera.position.x +=
      (this.targetX - this.camera.position.x) * 0.04;
    this.camera.position.y +=
      (this.targetY - this.camera.position.y) * 0.04;
    this.camera.lookAt(this.scene.position);

    this.renderer.render(this.scene, this.camera);
  }

  /* ── MOUSE PARALLAX ── */
  @HostListener('window:mousemove', ['$event'])
  onMouseMove(e: MouseEvent): void {
    const xN = e.clientX / window.innerWidth  - 0.5;
    const yN = e.clientY / window.innerHeight - 0.5;

    /* Camera target */
    this.targetX = xN * 55;
    this.targetY = -yN * 55;

    /* Orb parallax via CSS custom properties */
    if (this.gradientEl) {
      this.gradientEl.style.setProperty(
        '--ox1', `${(xN * 30).toFixed(1)}px`);
      this.gradientEl.style.setProperty(
        '--oy1', `${(yN * 20).toFixed(1)}px`);
      this.gradientEl.style.setProperty(
        '--ox2', `${(xN * 50).toFixed(1)}px`);
      this.gradientEl.style.setProperty(
        '--oy2', `${(yN * 35).toFixed(1)}px`);
      this.gradientEl.style.setProperty(
        '--ox3', `${(xN * -25).toFixed(1)}px`);
      this.gradientEl.style.setProperty(
        '--oy3', `${(yN * -18).toFixed(1)}px`);
    }
  }

  /* ── RESIZE ── */
  @HostListener('window:resize')
  onResize(): void {
    const W = window.innerWidth;
    const H = window.innerHeight;
    this.camera.aspect = W / H;
    this.camera.updateProjectionMatrix();
    this.renderer.setSize(W, H);
  }

  /* ── CLEANUP ── */
  ngOnDestroy(): void {
    cancelAnimationFrame(this.animationId);
    this.renderer.dispose();
    [this.layer1, this.layer2, this.layer3].forEach(l => {
      (l.geometry as THREE.BufferGeometry).dispose();
      (l.material as THREE.PointsMaterial).dispose();
    });
  }
}

