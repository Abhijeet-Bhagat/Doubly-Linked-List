  position: relative;
  z-index: 2;           /* sits above hero */
  
  /* Solid background — gradient matching the
     global bg so it feels seamless but blocks
     hero text from showing through */
  background:
    radial-gradient(
      ellipse 60% 75% at 18% 52%,
      rgba(0, 140, 100, 0.18) 0%,
      transparent 65%
    ),
    #040C0A;

  /* Fade in at the top edge so transition 
     from hero looks smooth not hard-cut */
  &::before {
    content: '';
    position: absolute;
    top: -80px;
    left: 0;
    right: 0;
    height: 80px;
