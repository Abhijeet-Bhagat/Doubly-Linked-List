════════════════════════════════════════════
TYPESCRIPT — COMPLETE SCROLL DRIVER
════════════════════════════════════════════

import {
  Component, AfterViewInit, OnDestroy,
  ViewChild, ElementRef, HostListener
} from '@angular/core';

/* Inside your landing component class: */

  @ViewChild('cardsSection') cardsSectionRef!: ElementRef;
  @ViewChild('card1')        card1Ref!: ElementRef;
  @ViewChild('card2')        card2Ref!: ElementRef;

  private sectionTop    = 0;
  private sectionHeight = 0;
  private ENTER_RANGE   = 300;  /* scroll px over which cards enter */
  private REST_RANGE    = 200;  /* scroll px where cards rest at 0 */
  private EXIT_RANGE    = 300;  /* scroll px over which cards exit */
  private STAGGER       = 80;   /* px offset between card 1 and 2 */
  private reducedMotion = false;

  ngAfterViewInit(): void {
    /* Check reduced motion preference */
    this.reducedMotion = window.matchMedia(
      '(prefers-reduced-motion: reduce)'
    ).matches;

    /* Measure section position after view renders */
    setTimeout(() => this.measureSection(), 300);

    /* Re-measure on resize */
  }

  @HostListener('window:resize')
  onResize(): void {
    this.measureSection();
  }

  private measureSection(): void {
    if (!this.cardsSectionRef) return;
    const rect = this.cardsSectionRef.nativeElement
      .getBoundingClientRect();
    this.sectionTop    = rect.top + window.scrollY;
    this.sectionHeight = rect.height;
  }

  @HostListener('window:scroll')
  onScroll(): void {
    if (this.reducedMotion) return;
    this.driveCards();
  }

  private driveCards(): void {
    const scrollY  = window.scrollY;
    const vH       = window.innerHeight;

    /* The scroll position at which the section becomes relevant
       is when the TOP of the section hits the BOTTOM of the
       viewport (section starts entering view) */
    const enterStart = this.sectionTop - vH;

    /* Define zone boundaries in scrollY space */
    const enterEnd   = enterStart  + this.ENTER_RANGE;
    const restEnd    = enterEnd    + this.REST_RANGE;
    const exitEnd    = restEnd     + this.EXIT_RANGE;

    let progress1: number;  /* -1 = off-left, 0 = resting, 1 = off-right */
    let progress2: number;

    if (scrollY < enterStart) {
      /* Before section — both cards off-screen LEFT */
      progress1 = -1;
      progress2 = -1;

    } else if (scrollY < enterEnd) {
      /* ENTERING — sliding in from left */
      /* progress goes 0 → 1 as scroll goes enterStart → enterEnd */
      const t = (scrollY - enterStart) / this.ENTER_RANGE;
      /* easeOutCubic — fast in, slows to rest */
      const eased = 1 - Math.pow(1 - t, 3);
      progress1 = -1 + eased;         /* -1 → 0 */
      /* card2 stagger: slightly behind card1 in the same range */
      const t2 = Math.max(0,
        (scrollY - enterStart - this.STAGGER) /
        (this.ENTER_RANGE - this.STAGGER)
      );
      const eased2 = 1 - Math.pow(1 - Math.min(t2, 1), 3);
      progress2 = -1 + eased2;

    } else if (scrollY < restEnd) {
      /* RESTING — both at translateX(0) */
      progress1 = 0;
      progress2 = 0;

    } else if (scrollY < exitEnd) {
      /* EXITING — sliding out to right */
      const t = (scrollY - restEnd) / this.EXIT_RANGE;
      const eased = Math.pow(t, 2);   /* easeInQuad — slow start, fast exit */
      progress1 = eased;              /* 0 → 1 */
      /* card2 lags card1 on exit — exits after card1 */
      const t2 = Math.max(0,
        (scrollY - restEnd - this.STAGGER) /
        (this.EXIT_RANGE - this.STAGGER)
      );
      progress2 = Math.pow(Math.min(t2, 1), 2);

    } else {
      /* Past section — both cards off-screen RIGHT */
      progress1 = 1;
      progress2 = 1;
    }

    /* Map progress to translateX pixels
       -1 = -110vw (off left)
        0 = 0px    (resting)
        1 = 110vw  (off right)  */
    const vW = window.innerWidth;
    const x1 = progress1 * vW * 1.1;
    const x2 = progress2 * vW * 1.1;

    /* Apply transforms directly to DOM — no Angular CD overhead */
    const el1 = this.card1Ref?.nativeElement as HTMLElement;
    const el2 = this.card2Ref?.nativeElement as HTMLElement;

    if (el1) el1.style.transform = `translateX(${x1.toFixed(1)}px)`;
    if (el2) el2.style.transform = `translateX(${x2.toFixed(1)}px)`;
  }

════════════════════════════════════════════
RULES — DO NOT CHANGE THESE
════════════════════════════════════════════

1. style.transform is set directly on the DOM element in the
   scroll handler — NOT via Angular binding [(ngStyle)] or
   [style.transform]. Direct DOM manipulation is required here
   because Angular's change detection cycle cannot keep up
   with scroll frequency (60fps). Using Angular bindings
   will cause visible lag and jank.

2. No CSS transition on .card-wrap — the scroll handler
   fires every frame. A CSS transition on top of that creates
   a double-easing effect where the card lags behind the
   calculation. The easing is IN the JavaScript math only.

3. easeOutCubic on ENTER (1 - Math.pow(1-t, 3)):
   cards accelerate then settle gently into position.
   easeInQuad on EXIT (Math.pow(t, 2)):
   cards start slow then accelerate off-screen.
   This asymmetry is intentional — enter feels like landing,
   exit feels like being pulled away.

4. STAGGER = 80px scroll distance, not 80ms time delay.
   Card 2 starts its animation 80 scroll-pixels after Card 1.
   Do not implement as setTimeout — it must be scroll-based.

5. overflow-x: hidden must be on the HOST or a parent
   wrapper — NOT on .cards-section itself. Putting it on
   the section clips the cards before they reach center.

6. measureSection() must run after a 300ms setTimeout in
   ngAfterViewInit — the DOM needs time to paint before
   getBoundingClientRect() returns accurate values.
   Running it immediately returns wrong coordinates.

7. Re-measure on window:resize — section position changes
   when viewport width changes. Stale measurements cause
   cards to animate at wrong scroll positions.

