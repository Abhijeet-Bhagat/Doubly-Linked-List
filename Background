  ngAfterViewInit(): void {
    this.gradientEl = document.querySelector(
      '.bg-gradient-layer') as HTMLElement;

    this.router.events
      .pipe(filter(e => e instanceof NavigationEnd))
      .subscribe((e: any) => {
        const url = e.url;
        const needsParticles = 
          url === '/' || url === '/ecosystem';

        if (needsParticles && !this.particlesActive) {
          this.initThree();
          this.particlesActive = true;
        } else if (!needsParticles && this.particlesActive) {
          cancelAnimationFrame(this.animationId);
          this.renderer?.dispose();
          this.particlesActive = false;
        }
      });

    /* Initial load */
    const initialUrl = this.router.url;
    const needsParticles = 
      initialUrl === '/' || initialUrl === '/ecosystem';
    if (needsParticles) {
      this.initThree();
      this.particlesActive = true;
    }
  }

  private particlesActive = false;

