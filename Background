import {
  Component, Input, OnInit, HostListener
} from '@angular/core';
import { Router } from '@angular/router';
import { Location } from '@angular/common';

@Component({
  selector: 'app-page-header',
  templateUrl: './page-header.component.html',
  styleUrls: ['./page-header.component.scss']
})
export class PageHeaderComponent {

  @Input() title = '';
  @Input() subtitle = '';
  @Input() showBack = true;

  isScrolled = false;

  constructor(
    private router: Router,
    private location: Location
  ) {}

  @HostListener('window:scroll')
  onScroll(): void {
    this.isScrolled = window.scrollY > 40;
  }

  goBack(): void {
    /* Check if there is Angular navigation history */
    const state = this.location.getState() as any;
    const hasHistory = state && state.navigationId > 1;

    if (hasHistory) {
      /* There is a previous Angular route — go back */
      this.location.back();
    } else {
      /* No history — user came directly to this URL.
         Navigate to landing and scroll to cards section */
      this.router.navigate(['/'], {
        fragment: 'discover'
      }).then(() => {
        /* Small delay for page to render, then scroll */
        setTimeout(() => {
          const el = document.getElementById('discover');
          if (el) {
            el.scrollIntoView({ behavior: 'smooth' });
          }
        }, 400);
      });
    }
  }
}

