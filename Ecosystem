    rgba(0, 200, 140, 0.4),
    rgba(0, 200, 140, 0.05)
  );
  margin: 0 auto;
}

/* ── PHASES GRID ── */
.phases-grid {
  display: grid;
  /* 6 equal columns on desktop */
  grid-template-columns: repeat(6, 1fr);
  gap: 0;
  padding: 0 5vw 4rem;
  /* Columns separated by border-right, not gap */
}

/* ── PHASE COLUMN ── */
.phase-col {
  padding: 0 10px;
  border-right: 1px solid rgba(255, 255, 255, 0.04);

  &:first-child { padding-left: 0; }
  &:last-child {
    padding-right: 0;
    border-right: none;
  }
}

/* ── PHASE HEADER ── */
.phase-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0.6rem 0 0.75rem;
  margin-bottom: 0.6rem;
  border-bottom: 1px solid rgba(0, 200, 140, 0.15);
  position: sticky;
  top: 0;
  background: transparent;
  /* slight blur so cards scroll behind header */
  backdrop-filter: blur(4px);
}

.phase-label {
  font-family: 'Inter', sans-serif;
  font-size: 0.7rem;
  font-weight: 600;
  color: #00C896;
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

.phase-count {
  font-family: 'Inter', sans-serif;
  font-size: 0.65rem;
  font-weight: 400;
  color: rgba(0, 200, 140, 0.4);
  background: rgba(0, 200, 140, 0.06);
  border: 1px solid rgba(0, 200, 140, 0.12);
  border-radius: 100px;
  padding: 1px 6px;
  line-height: 1.6;
}

/* ── SYSTEM CARDS ── */
.phase-systems {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.sys-card {
  background: rgba(4, 12, 10, 0.65);
  border: 1px solid rgba(0, 200, 140, 0.08);
  border-radius: 7px;
  padding: 8px 10px;
  display: flex;
  align-items: flex-start;
  gap: 8px;
  cursor: default;

  /* Staggered entrance animation */
  opacity: 0;
  animation: card-enter 0.5s ease forwards;

  transition:
    border-color 0.2s ease,
    background 0.2s ease,
    transform 0.2s ease;

  &:hover {
    border-color: rgba(0, 200, 140, 0.28);
    background: rgba(4, 12, 10, 0.88);
    transform: translateY(-2px);
  }
}

@keyframes card-enter {
  from {
    opacity: 0;
    filter: blur(8px);
    transform: translateY(6px);
  }
  to {
    opacity: 1;
    filter: blur(0px);
    transform: translateY(0);
  }
}

.sys-icon {
  width: 24px;
  height: 24px;
  border-radius: 5px;
  background: rgba(0, 200, 140, 0.07);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 11px;
  flex-shrink: 0;
  margin-top: 1px;
}

.sys-info {
  display: flex;
  flex-direction: column;
  gap: 2px;
  min-width: 0;
}

.sys-name {
  font-family: 'Inter', sans-serif;
  font-size: 0.78rem;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.85);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.sys-cat {
  font-family: 'Inter', sans-serif;
  font-size: 0.65rem;
  font-weight: 300;
  color: rgba(0, 200, 140, 0.42);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* ══════════════════════════════════════
   RESPONSIVE — MOBILE FIRST
   ══════════════════════════════════════ */

/* Tablet — 3 columns, 2 rows of phases */
@media (max-width: 1024px) {
  .phases-grid {
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .phase-col {
    border-right: none;
    padding: 0;
    background: rgba(4, 12, 10, 0.4);
    border: 0.5px solid rgba(0, 200, 140, 0.08);
    border-radius: 10px;
    padding: 0.75rem;
  }

  .eco-topbar {
    grid-template-columns: auto 1fr;
    grid-template-rows: auto auto;
  }

  .eco-title-block {
    grid-column: 1 / -1;
    text-align: center;
  }

  .topbar-spacer { display: none; }
}

/* Mobile — 2 columns */
@media (max-width: 640px) {
  .phases-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
    padding: 0 4vw 3rem;
  }

  .eco-topbar {
    grid-template-columns: 1fr;
    text-align: center;
    gap: 0.75rem;
    padding: 1.2rem 5vw 0.75rem;
  }

  .back-btn {
    justify-content: center;
  }

  .eco-title {
    font-size: clamp(1.4rem, 6vw, 1.8rem);
  }

  .eco-subtitle {
    font-size: 0.78rem;
  }

  .workday-banner {
    margin: 0.5rem 4vw 0;
    padding: 0.75rem 1rem;
  }

  .workday-badge { display: none; }

  .topbar-spacer { display: none; }
}

/* Very small — 1 column */
@media (max-width: 380px) {
  .phases-grid {
    grid-template-columns: 1fr;
  }
}

/* Reduced motion */
@media (prefers-reduced-motion: reduce) {
  .sys-card {
    animation: none;
    opacity: 1;
  }
  .region-dot {
    animation: none;
  }
}

