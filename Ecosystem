:host {
  display: block;
  min-height: 100vh;
  background: transparent;
  overflow-x: hidden;
}

/* ── TOP BAR ── */
.eco-topbar {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  padding: 1.5rem 5vw 1rem;
  gap: 1rem;
}

.back-btn {
  display: flex;
  align-items: center;
  gap: 8px;
  background: transparent;
  border: none;
  cursor: pointer;
  padding: 6px 0;
  color: rgba(255, 255, 255, 0.65);
  font-family: 'Inter', sans-serif;
  font-size: 0.88rem;
  font-weight: 500;
  letter-spacing: 0.02em;
  transition: color 0.2s ease;
  width: fit-content;

  &:hover {
    color: #ffffff;

    .back-arrow {
      transform: translateX(-5px);
    }
  }
}

.back-arrow {
  font-size: 1.1rem;
  display: inline-block;
  transition: transform 0.25s cubic-bezier(0.16, 1, 0.3, 1);
  font-weight: 700;
}

.back-label {
  font-size: 0.88rem;
  font-weight: 600;
}

.eco-title-block {
  text-align: center;
}

.eco-title {
  font-family: 'Syne', sans-serif;
  font-size: clamp(1.6rem, 3.5vw, 2.4rem);
  font-weight: 800;
  color: #ffffff;
  letter-spacing: -0.02em;
  margin: 0 0 0.5rem;
  line-height: 1.1;
}

/* Region subtitle — prominent, not a footnote */
.eco-subtitle {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  font-family: 'Inter', sans-serif;
  font-size: 0.88rem;
  font-weight: 400;
  color: rgba(190, 225, 215, 0.7);
}

.region-dot {
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: #00C896;
  flex-shrink: 0;
  box-shadow: 0 0 6px rgba(0, 200, 140, 0.6);
  /* Pulse animation — signals "live" data */
  animation: pulse-dot 2.5s ease-in-out infinite;
}

@keyframes pulse-dot {
  0%, 100% { opacity: 1; box-shadow: 0 0 6px rgba(0,200,140,0.6); }
  50%       { opacity: 0.6; box-shadow: 0 0 12px rgba(0,200,140,0.3); }
}

.region-label {
  font-weight: 500;
  color: rgba(255, 255, 255, 0.85);
}

.region-sep {
  color: rgba(255, 255, 255, 0.2);
}

.region-count {
  color: #00C896;
  font-weight: 500;
}

.topbar-spacer {
  /* balances the back button so title stays centered */
}

/* ── WORKDAY BANNER ── */
.workday-banner {
  margin: 0.5rem 5vw 0;
  border: 0.5px solid rgba(0, 200, 140, 0.2);
  border-top: 2px solid #00C896;
