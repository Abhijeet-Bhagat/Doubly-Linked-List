<div
  *ngFor="let phase of phases"
  class="phase-col"
  [style.background]="phase.colors.panel"
  [style.border-color]="phase.colors.border">

  <div class="phase-header"
    [style.border-bottom-color]="phase.colors.border">
    <span class="phase-label"
      [style.color]="phase.colors.header">
      {{ phase.label }}
    </span>
    <span class="phase-count"
      [style.color]="phase.colors.accent"
      [style.border-color]="phase.colors.cardBorder"
      [style.background]="phase.colors.iconBg">
      {{ phase.systems.length }}
    </span>
  </div>

  <div class="phase-systems">
    <div
      *ngFor="let sys of visibleSystems(phase); 
              let i = index"
      class="sys-card"
      [style.background]="phase.colors.card"
      [style.border-color]="phase.colors.cardBorder"
      [style.animation-delay]="(i * 60) + 'ms'">

      <div class="sys-icon"
        [style.background]="phase.colors.iconBg"
        [style.border-color]="phase.colors.cardBorder">
        {{ sys.icon }}
      </div>

      <div class="sys-info">
        <span class="sys-name">{{ sys.name }}</span>
        <span class="sys-cat"
          [style.color]="phase.colors.accent">
          {{ sys.category }}
        </span>
      </div>

    </div>

    <!-- EXPAND / COLLAPSE BUTTON -->
    <!-- Only shows if phase has more than 4 systems -->
    <button
      *ngIf="phase.systems.length > 4"
      class="expand-btn"
      [style.color]="phase.colors.accent"
      [style.border-color]="phase.colors.cardBorder"
      (click)="togglePhase(phase.id)">
      <span class="expand-icon">
        {{ expandedPhases.has(phase.id) ? '↑' : '↓' }}
      </span>
      <span class="expand-label">
        {{ expandedPhases.has(phase.id)
            ? 'Show less'
            : '+' + (phase.systems.length - 4) + ' more' }}
      </span>
    </button>

  </div>
</div>

