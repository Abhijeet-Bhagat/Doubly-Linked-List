CHANGE 3 — EXPAND/COLLAPSE AFTER 4 CARDS
════════════════════════════════════════

In ecosystem.component.ts add:

  expandedPhases = new Set<string>();

  togglePhase(phaseId: string): void {
    if (this.expandedPhases.has(phaseId)) {
      this.expandedPhases.delete(phaseId);
    } else {
      this.expandedPhases.add(phaseId);
    }
  }

  visibleSystems(phase: Phase): EcoSystem[] {
    if (this.expandedPhases.has(phase.id)) {
      return phase.systems;          /* show all */
    }
    return phase.systems.slice(0, 4); /* show first 4 */
  }

