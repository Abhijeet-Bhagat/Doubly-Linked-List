import {
  Component, OnInit, OnDestroy
} from '@angular/core';
import { Router } from '@angular/router';

interface Persona {
  id: string;
  label: string;
  desc: string;
  icon: string;
  route: string;
}

@Component({
  selector: 'app-floating-persona-btn',
  templateUrl: './floating-persona-btn.component.html',
  styleUrls: ['./floating-persona-btn.component.scss']
})
export class FloatingPersonaBtnComponent implements OnInit {

  isOpen = false;

  personas: Persona[] = [
    {
      id: 'associate',
      label: 'Associate',
      desc: 'Day-to-day tools and moments',
      icon: '👤',
      route: '/persona/associate'
    },
    {
      id: 'manager',
      label: 'Manager',
      desc: 'Team tools and leadership flows',
      icon: '👥',
      route: '/persona/manager'
    },
    {
      id: 'hr-partner',
      label: 'HR Partner',
      desc: 'Policy, process and people ops',
      icon: '🛡',
      route: '/persona/hr-partner'
    }
  ];

  activePersonaId = 'associate';

  get currentPersona(): string {
    return this.personas.find(
      p => p.id === this.activePersonaId
    )?.label ?? 'Associate';
  }

  constructor(private router: Router) {}

  ngOnInit(): void {
    /* Set active persona based on current route */
    const url = this.router.url;
    const match = this.personas.find(
      p => url.includes(p.id)
    );
    if (match) this.activePersonaId = match.id;
  }

  toggleMenu(): void {
    this.isOpen = !this.isOpen;
  }

  closeMenu(): void {
    this.isOpen = false;
  }

  switchPersona(persona: Persona): void {
    this.activePersonaId = persona.id;
    this.isOpen = false;
    this.router.navigate([persona.route]);
  }
}

