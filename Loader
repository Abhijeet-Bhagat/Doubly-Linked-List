### Exit animation — the reveal

When progress hits 100% and the 400ms pause ends:

  private exitLoader(): void {
    const loader = document.getElementById('loader-screen');
    if (!loader) return;

    // 1. First: the line and all elements fade out (200ms)
    const inner = loader.querySelector('.loader-inner') as HTMLElement;
    if (inner) {
      inner.style.transition = 'opacity 0.2s ease';
      inner.style.opacity = '0';
    }

    // 2. Then: entire loader fades to transparent (500ms)
    setTimeout(() => {
      loader.style.transition = 'opacity 0.5s ease';
      loader.style.opacity = '0';
    }, 250);

    // 3. Then: remove from DOM, trigger hero reveal
    setTimeout(() => {
      loader.style.display = 'none';
      // Dispatch event so landing page component can start 
      // its own entrance animations
      document.dispatchEvent(new CustomEvent('loaderComplete'));
    }, 800);
  }

