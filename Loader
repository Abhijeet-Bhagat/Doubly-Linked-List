### Angular integration

Create a standalone LoaderComponent:
  selector: 'app-loader'
  
In app.component.html:
  <app-loader *ngIf="showLoader"></app-loader>
  <app-landing *ngIf="!showLoader || loaderExiting"></app-landing>

In app.component.ts:
  showLoader = true;
  loaderExiting = false;

  ngOnInit(): void {
    document.addEventListener('loaderComplete', () => {
      this.showLoader = false;
    });
  }

In loader.component.ts:
  ngAfterViewInit(): void {
    this.startLoader();
    this.startDotAnimation(); // for the "INITIALIZING.." cycling
  }

  ngOnDestroy(): void {
    cancelAnimationFrame(this.animationId);
    clearInterval(this.dotInterval);
  }

  private dotInterval!: ReturnType<typeof setInterval>;
  private dotCount = 1;

  private startDotAnimation(): void {
    this.dotInterval = setInterval(() => {
      this.dotCount = this.dotCount >= 3 ? 1 : this.dotCount + 1;
      const el = document.getElementById('loader-initializing');
      if (el) el.textContent = 'INITIALIZING' + '.'.repeat(this.dotCount);
    }, 500);
  }

