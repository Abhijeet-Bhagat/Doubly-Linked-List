### Progress animation — exact behavior

The loader runs a fake progress from 0 to 100 over ~3.2 seconds.
It does NOT move linearly — it eases:

  0% → 60%  :  fast  (0.8s) — feels like it's loading quickly
  60% → 85% :  slow  (1.4s) — deliberate pause, builds tension
  85% → 100%:  fast  (1.0s) — snaps to completion

Implement this with a custom easing function:

  private progress = 0;
  private animationId!: number;

  private startLoader(): void {
    const startTime = performance.now();
    const totalDuration = 3200;

    const easeProgress = (t: number): number => {
      // Custom three-phase easing
      if (t < 0.25) {
        // Phase 1: fast (0 → 60%)
        return (t / 0.25) * 0.60;
      } else if (t < 0.69) {
        // Phase 2: slow (60% → 85%)
        return 0.60 + ((t - 0.25) / 0.44) * 0.25;
      } else {
        // Phase 3: fast (85% → 100%)
        return 0.85 + ((t - 0.69) / 0.31) * 0.15;
      }
    };

    const tick = (now: number) => {
      const elapsed = now - startTime;
      const t = Math.min(elapsed / totalDuration, 1);
      this.progress = Math.floor(easeProgress(t) * 100);
      
      this.updateLoaderDOM();
      
      if (t < 1) {
        this.animationId = requestAnimationFrame(tick);
      } else {
        this.progress = 100;
        this.updateLoaderDOM();
        // Wait 400ms at 100% then exit
        setTimeout(() => this.exitLoader(), 400);
      }
    };

    this.animationId = requestAnimationFrame(tick);
  }

  private updateLoaderDOM(): void {
    // Update percentage text
    const pctEl = document.getElementById('loader-pct');
    if (pctEl) pctEl.textContent = `${this.progress}%`;

    // Update dot position
    const dotEl = document.getElementById('loader-dot');
    if (dotEl) {
      // Dot travels from 5vw to 88vw (not edge to edge — leaves margins)
      const startVw = 5;
      const endVw = 88;
      const pos = startVw + (this.progress / 100) * (endVw - startVw);
      dotEl.style.left = `${pos}vw`;
    }
  }

