### SCSS — complete

/* === CSS CUSTOM PROPERTIES (add to :root if not already present) === */
:root {
  --header-height: 60px;
  --corporate-green: #00873C;   /* Fidelity/CST brand green — use ONLY for accents */
  --color-bg-primary: #0A0D12;
}

.site-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  height: var(--header-height);

  /* Default state: transparent */
  background: transparent;
  border-bottom: 1px solid transparent;
  backdrop-filter: blur(0px);

  /* Smooth transitions for all properties */
  transition:
    background 0.35s ease,
    border-color 0.35s ease,
    backdrop-filter 0.35s ease,
    box-shadow 0.35s ease;

  /* Slide animation — starts off-screen */
  transform: translateY(-100%);
  animation: header-enter 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.3s forwards;
  /* 0.3s delay — lets the hero load before header appears */
}

@keyframes header-enter {
  from { transform: translateY(-100%); }
  to   { transform: translateY(0); }
}

/* === SCROLLED STATE — class added by TypeScript === */
.site-header.scrolled {
  background: rgba(10, 13, 18, 0.92);
  border-bottom-color: rgba(255, 255, 255, 0.06);
  backdrop-filter: blur(12px) saturate(1.4);
  box-shadow: 0 1px 40px rgba(0, 0, 0, 0.4);
}

